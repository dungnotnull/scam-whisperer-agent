{
  "expo": {
    "name": "Scam Whisperer",
    "slug": "scam-whisperer",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": { "backgroundColor": "#ffffff" },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "vn.scamwhisperer.app", "infoPlist": { "NSMicrophoneUsageDescription": "Cho phép nói chuyện với Cháu để kiểm tra tin nhắn", "NSCameraUsageDescription": "Cho phép chụp ảnh tin nhắn để kiểm tra", "NSPhotoLibraryUsageDescription": "Cho phép chọn ảnh tin nhắn để kiểm tra" } },
    "android": { "package": "vn.scamwhisperer.app", "adaptiveIcon": { "backgroundColor": "#ffffff" }, "permissions": ["RECORD_AUDIO", "CAMERA", "READ_EXTERNAL_STORAGE"] },
    "plugins": ["expo-image-picker", "expo-av"]
  }
}
