# =============================================================================
# scam-whisperer-agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.

# ─── REQUIRED ────────────────────────────────────────────────────────────────
# Anthropic Claude API — used for Vision analysis + LLM classification + explanations
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── RECOMMENDED ────────────────────────────────────────────────────────────
# Google Cloud TTS — Vietnamese text-to-speech (vi-VN-Wavenet voices)
# https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
GOOGLE_TTS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Safe Browsing API — URL reputation check
# https://developers.google.com/safe-browsing
GOOGLE_SAFE_BROWSING_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OPTIONAL ────────────────────────────────────────────────────────────────

# FPT.AI TTS — alternative Vietnamese TTS with better regional accents
# https://fpt.ai/tts
FPT_AI_TTS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# VirusTotal API — phone number / URL reputation check
# https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Zalo Notification Service (ZNS) — family alert delivery
# https://zalo.me/zns
ZALO_APP_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZALO_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── SERVER CONFIG ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Redis — used for session caching, lesson tracking, rate limiting
REDIS_URL=redis://localhost:6379

# ─── MODEL SELECTION ──────────────────────────────────────────────────────────
# Claude model to use for vision analysis and text reasoning
ANTHROPIC_VISION_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TEXT_MODEL=claude-sonnet-4-20250514

# HuggingFace model for semantic search over knowledge base (sentence-transformers)
# Default: paraphrase-multilingual-MiniLM-L12-v2
HF_SEMANTIC_MODEL=paraphrase-multilingual-MiniLM-L12-v2
